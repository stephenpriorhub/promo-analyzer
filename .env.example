# Required
ANTHROPIC_API_KEY=sk-ant-...

# Brain vault — GitHub repo (owner/repo format).
# Notes are written via the GitHub Contents API when GITHUB_TOKEN is set.
# Defaults to stephenpriorhub/brain if not set.
BRAIN_GITHUB_REPO=stephenpriorhub/brain

# GitHub personal access token with repo read+write access.
# When set, "Add to Brain" writes directly to the GitHub repo (works on Railway),
# and the analyzer READS Copywriting Principles + guru profiles from the vault
# via the Contents API on every run.
# When not set, falls back to local filesystem write via BRAIN_DIR.
GITHUB_TOKEN=github_pat_...

# ── Shared Brain API ("the librarian") ───────────────────────────────────────
# On every successful analysis the analyzer appends one Promo Pattern Ledger row
# via the shared Brain API (kind:"promo-ledger-row"), hosted in brain-map at
# POST {BRAIN_API_URL}/api/intelligence. The Brain API is the ONLY writer of the
# ledger file — the analyzer never writes it directly. A failure here is logged
# and never breaks serving the analysis.
#
# BRAIN_API_URL defaults to the brain-map live URL if not set.
BRAIN_API_URL=https://brain.oxfordhub.app
# Shared auth token between apps and brain-map (same secret as brain-map's
# HUB_API_TOKEN). Required for the ledger write; if unset, the write is skipped.
HUB_API_TOKEN=...

# Optional — override the data directory (reviews.json + uploaded files).
# Set to a Railway volume mount path for persistence, e.g. /data
# DATA_DIR=/data

# Optional — vault paths (set automatically by scripts/start.sh on Railway
# when BRAIN_GITHUB_REPO + GITHUB_TOKEN are provided).
# BRAIN_VAULT_DIR=/tmp/brain
# BRAIN_DIR=/tmp/brain/Resources/Promo Analysis/Promo Analysis Tool

# ── Performance sheet (Performance tab) ──────────────────────────────────────
# Real-world promo results by creative code. CSV import always works; these
# enable the "Sync Google Sheet" button. Share the sheet (viewer) with the
# service account's client_email.
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# PERFORMANCE_SHEET_ID=1AbC...
# PERFORMANCE_SHEET_RANGE=Sheet1
